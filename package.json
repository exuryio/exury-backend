{
  "name": "@exuryio/backend",
  "version": "1.0.0",
  "description": "Exury Backend API - EU Crypto Exchange On/Off-Ramp",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npx tsc",
    "start": "node dist/server.js",
    "migrate": "node-pg-migrate",
    "migrate:up": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down",
    "migrate:run": "node scripts/run-migrations.js",
    "lint": "eslint src --ext .ts",
    "test": "echo \"No tests specified\" && exit 0",
    "cleanup:users": "tsx scripts/cleanup-test-users.ts",
    "cleanup:user": "tsx scripts/cleanup-test-users.ts"
  },
  "keywords": [
    "exury",
    "crypto",
    "exchange",
    "fiat",
    "onramp"
  ],
  "author": "exuryio",
  "license": "MIT",
  "dependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-pg-migrate": "^6.2.2",
    "nodemailer": "^7.0.10",
    "pg": "^8.11.3",
    "rate-limiter-flexible": "^3.0.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/nodemailer": "^7.0.4",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "eslint": "^10.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.58.1"
  }
}
